            "url": {
              "raw": "{{baseUrl}}/quiz/{{quizId_DB}}/start",
              "host": ["{{baseUrl}}"],
              "path": ["quiz", "{{quizId_DB}}", "start"]
            }
          }
        },
        {
          "name": "Get Leaderboard - Databases Quiz",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/quiz/{{quizId_DB}}/leaderboard",
              "host": ["{{baseUrl}}"],
              "path": ["quiz", "{{quizId_DB}}", "leaderboard"]
            }
          }
        },
        {
          "name": "Start Python+Networking Quiz",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"studentId\": \"{{studentId}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/quiz/{{quizId_PY}}/start",
              "host": ["{{baseUrl}}"],
              "path": ["quiz", "{{quizId_PY}}", "start"]
            }
